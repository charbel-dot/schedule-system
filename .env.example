# Copy to .env for local development, or set these in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.

# --- Required in production -------------------------------------------------
# Manager login password. If unset, manager login is disabled.
MANAGER_PASSWORD=change-this-to-a-strong-password

# Upstash Redis (or Vercel KV). Required on Vercel for data + sessions.
# Add the Upstash integration from the Vercel Marketplace and these are
# injected automatically; or paste them from the Upstash console.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# (Vercel KV's KV_REST_API_URL / KV_REST_API_TOKEN are also accepted.)

# --- Optional --------------------------------------------------------------
# Business name shown in worker notifications.
BUSINESS_NAME=New Tronics

# Automatic SMS via Twilio. Leave blank to use the free WhatsApp links instead.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
